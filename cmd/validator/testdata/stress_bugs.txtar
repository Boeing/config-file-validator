name=test
-- ext_exclude/config.ini --
[section]
key=value

-- glob_test/tsconfig.json --
// glob test
{"compilerOptions": {}}
-- glob_test/good.json --
{"key": "value"}

-- jsonc_stdin.jsonc --
// comment
{"key": "value"}
-- json_stdin.json --
{"key": "value"}

