# ============================================================
# Real-world JSON Schema validation tests
# ============================================================

# --- package.json (npm) ---

# Valid package.json
exec validator valid_package.json
stdout '✓'

# Invalid package.json (version must be string)
! exec validator invalid_package.json
stdout '×'
stdout 'schema validation failed'

# --- tsconfig.json (TypeScript) ---

# Valid tsconfig.json
exec validator valid_tsconfig.json
stdout '✓'

# Invalid tsconfig.json (compilerOptions.target must be string)
! exec validator invalid_tsconfig.json
stdout '×'
stdout 'schema validation failed'

# --- .eslintrc.json (ESLint) ---

# Valid eslintrc
exec validator valid_eslintrc.json
stdout '✓'

# --- GitHub Actions workflow ---

# Valid workflow
exec validator valid_workflow.json
stdout '✓'

# Invalid workflow (missing jobs)
! exec validator invalid_workflow.json
stdout '×'
stdout 'schema validation failed'

# --- Local schema: strict config ---

# Valid against local strict schema
exec validator valid_strict.json
stdout '✓'

# Missing required field
! exec validator missing_required.json
stdout '×'
stdout 'schema validation failed'

# Wrong type
! exec validator wrong_type.json
stdout '×'
stdout 'schema validation failed'

# Extra property not allowed
! exec validator extra_property.json
stdout '×'
stdout 'schema validation failed'

# Value out of range
! exec validator out_of_range.json
stdout '×'
stdout 'schema validation failed'

# Enum violation
! exec validator bad_enum.json
stdout '×'
stdout 'schema validation failed'

# --- Local schema: array validation ---

# Valid array
exec validator valid_array.json
stdout '✓'

# Too few items
! exec validator too_few_items.json
stdout '×'
stdout 'schema validation failed'

# Wrong item type
! exec validator wrong_item_type.json
stdout '×'
stdout 'schema validation failed'

# --- Mixed: files with and without $schema ---

# File without $schema passes (syntax only)
exec validator no_schema.json
stdout '✓'

# --require-schema fails file without $schema
! exec validator --require-schema no_schema.json
stdout 'no schema declared'

# --require-schema passes file with $schema
exec validator --require-schema valid_strict.json
stdout '✓'

# Multiple files: one with schema, one without
exec validator valid_strict.json no_schema.json
stdout '✓.*valid_strict'
stdout '✓.*no_schema'

# Multiple files with --require-schema: one fails
! exec validator --require-schema valid_strict.json no_schema.json
stdout '✓.*valid_strict'
stdout '×.*no_schema'

# --- Non-JSON files without SchemaValidator unaffected ---

exec validator good.ini
stdout '✓'

exec validator --require-schema good.ini
stdout '✓'

# ============================================================
# Test data files
# ============================================================

-- valid_package.json --
{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "my-package",
  "version": "1.0.0"
}
-- invalid_package.json --
{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "my-package",
  "version": 123
}
-- valid_tsconfig.json --
{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "strict": true
  }
}
-- invalid_tsconfig.json --
{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "compilerOptions": {
    "target": 999,
    "module": "commonjs"
  }
}
-- valid_eslintrc.json --
{
  "$schema": "https://json.schemastore.org/eslintrc.json",
  "env": {
    "browser": true,
    "es2021": true
  },
  "rules": {}
}
-- valid_workflow.json --
{
  "$schema": "https://json.schemastore.org/github-workflow.json",
  "name": "CI",
  "on": "push",
  "jobs": {
    "build": {
      "runs-on": "ubuntu-latest",
      "steps": [
        {"uses": "actions/checkout@v4"}
      ]
    }
  }
}
-- invalid_workflow.json --
{
  "$schema": "https://json.schemastore.org/github-workflow.json",
  "name": "CI",
  "on": "push"
}
-- strict_schema.json --
{
  "type": "object",
  "required": ["host", "port", "database"],
  "properties": {
    "host": { "type": "string", "minLength": 1 },
    "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
    "database": { "type": "string" },
    "ssl": { "type": "boolean" },
    "log_level": { "type": "string", "enum": ["debug", "info", "warn", "error"] }
  },
  "additionalProperties": false
}
-- valid_strict.json --
{
  "$schema": "strict_schema.json",
  "host": "localhost",
  "port": 5432,
  "database": "myapp",
  "ssl": true,
  "log_level": "info"
}
-- missing_required.json --
{
  "$schema": "strict_schema.json",
  "host": "localhost",
  "port": 5432
}
-- wrong_type.json --
{
  "$schema": "strict_schema.json",
  "host": "localhost",
  "port": "not_a_number",
  "database": "myapp"
}
-- extra_property.json --
{
  "$schema": "strict_schema.json",
  "host": "localhost",
  "port": 5432,
  "database": "myapp",
  "unknown_field": true
}
-- out_of_range.json --
{
  "$schema": "strict_schema.json",
  "host": "localhost",
  "port": 99999,
  "database": "myapp"
}
-- bad_enum.json --
{
  "$schema": "strict_schema.json",
  "host": "localhost",
  "port": 5432,
  "database": "myapp",
  "log_level": "verbose"
}
-- array_schema.json --
{
  "type": "object",
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  }
}
-- valid_array.json --
{
  "$schema": "array_schema.json",
  "items": ["one", "two", "three"]
}
-- too_few_items.json --
{
  "$schema": "array_schema.json",
  "items": []
}
-- wrong_item_type.json --
{
  "$schema": "array_schema.json",
  "items": ["valid", 123, "also_valid"]
}
-- no_schema.json --
{"key": "value"}
-- good.ini --
[section]
key=value
