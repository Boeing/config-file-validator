# Format check on well-formatted JSON passes
exec validator --check-format=json formatted.json
stdout '✓'

# Format check on unformatted JSON fails
! exec validator --check-format=json unformatted.json
stdout 'format check failed'

# Format check on unsupported type fails at startup
! exec validator --check-format=yaml good.yaml
stderr 'format validation is not supported'

# Invalid format type
! exec validator --check-format=notreal .

# Format check does not apply to non-matching types
exec validator --check-format=json good.yaml
stdout '✓'
! stdout 'format check failed'

-- formatted.json --
{
  "key": "value"
}
-- unformatted.json --
{"key":"value"}
-- good.yaml --
key: value
