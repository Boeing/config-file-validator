# Glob pattern matches json files
exec cfv check --globbing 'files/*.json'
stdout '✓.*good.json'
! stdout 'good.yaml'

# Glob with no matches succeeds with no output
exec cfv check --globbing 'files/*.nomatch'

# Globbing cannot be used with exclude-dirs
! exec cfv check --globbing --exclude-dirs=sub 'files/*.json'

# Globbing cannot be used with exclude-file-types
! exec cfv check --globbing --exclude-file-types=yaml 'files/*.json'

# Globbing cannot be used with file-types
! exec cfv check --globbing --file-types=json 'files/*.json'

-- files/good.json --
{"key": "value"}
-- files/good.yaml --
key: value
