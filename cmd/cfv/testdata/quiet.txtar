# Quiet suppresses stdout on success
exec cfv check --quiet good.json
! stdout .

# Quiet still exits 1 on failure
! exec cfv check --quiet bad.json
! stdout .

# Quiet with reporter to file still writes file
exec cfv check --quiet --reporter=json:out.json good.json
! stdout .
exists out.json

-- good.json --
{"key": "value"}
-- bad.json --
{"bad":}
