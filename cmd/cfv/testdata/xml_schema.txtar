# ============================================================
# XML DTD validation (syntax-level)
# ============================================================

# Valid DTD
exec cfv check dtd_valid.xml
stdout '✓'

# Missing required element
! exec cfv check dtd_missing_elem.xml
stdout '×'

# Extra element not in DTD
! exec cfv check dtd_extra_elem.xml
stdout '×'

# Wrong root element
! exec cfv check dtd_wrong_root.xml
stdout '×'

# Required attribute present
exec cfv check dtd_req_attr.xml
stdout '✓'

# Required attribute missing
! exec cfv check dtd_req_attr_missing.xml
stdout '×'

# Fixed attribute correct value
exec cfv check dtd_fixed_attr.xml
stdout '✓'

# Fixed attribute wrong value
! exec cfv check dtd_fixed_attr_wrong.xml
stdout '×'

# Choice content model (alpha | beta) — valid
exec cfv check dtd_choice.xml
stdout '✓'

# Choice content model — both present (invalid)
! exec cfv check dtd_choice_both.xml
stdout '×'

# Mixed content (#PCDATA | bold)*
exec cfv check dtd_mixed.xml
stdout '✓'

# --no-schema does NOT skip DTD (DTD is syntax, not schema)
! exec cfv check --no-schema dtd_missing_elem.xml
stdout '×'

# ============================================================
# XML XSD validation (schema-level)
# ============================================================

# Valid XSD
exec cfv check xsd_valid.xml
stdout '✓'

# Invalid type
! exec cfv check xsd_invalid.xml
stdout '×'
stdout 'error:'

# No schema passes syntax-only
exec cfv check plain.xml
stdout '✓'

# --require-schema fails without XSD
! exec cfv check --require-schema plain.xml
stdout '×'
stdout 'no schema declared'

# --require-schema passes with XSD
exec cfv check --require-schema xsd_valid.xml
stdout '✓'

# --no-schema skips XSD validation
exec cfv check --no-schema xsd_invalid.xml
stdout '✓'

# --schema-map with XSD valid
exec cfv check --schema-map=mapped.xml:schema.xsd mapped.xml
stdout '✓'

# --schema-map with XSD invalid
! exec cfv check --schema-map=mapped_bad.xml:schema.xsd mapped_bad.xml
stdout '×'
stdout 'error:'

# ============================================================
# DTD + XSD together
# ============================================================

# Both DTD and XSD present, both valid
exec cfv check dtd_and_xsd.xml
stdout '✓'

# DTD valid but XSD fails (wrong type)
! exec cfv check dtd_ok_xsd_bad.xml
stdout '×'
stdout 'error:'

# DTD fails (missing element) — never reaches XSD
! exec cfv check dtd_bad_xsd_ok.xml
stdout '×'

# ============================================================
# Test data
# ============================================================

-- dtd_valid.xml --
<?xml version="1.0"?>
<!DOCTYPE config [
  <!ELEMENT config (host, port)>
  <!ELEMENT host (#PCDATA)>
  <!ELEMENT port (#PCDATA)>
]>
<config><host>db.example.com</host><port>5432</port></config>
-- dtd_missing_elem.xml --
<?xml version="1.0"?>
<!DOCTYPE config [
  <!ELEMENT config (host, port)>
  <!ELEMENT host (#PCDATA)>
  <!ELEMENT port (#PCDATA)>
]>
<config><host>db.example.com</host></config>
-- dtd_extra_elem.xml --
<?xml version="1.0"?>
<!DOCTYPE config [
  <!ELEMENT config (host, port)>
  <!ELEMENT host (#PCDATA)>
  <!ELEMENT port (#PCDATA)>
]>
<config><host>db.example.com</host><port>5432</port><extra>bad</extra></config>
-- dtd_wrong_root.xml --
<?xml version="1.0"?>
<!DOCTYPE config [
  <!ELEMENT config (host)>
  <!ELEMENT host (#PCDATA)>
]>
<wrong><host>db.example.com</host></wrong>
-- dtd_req_attr.xml --
<?xml version="1.0"?>
<!DOCTYPE doc [
  <!ELEMENT doc EMPTY>
  <!ATTLIST doc id ID #REQUIRED>
]>
<doc id="x1"/>
-- dtd_req_attr_missing.xml --
<?xml version="1.0"?>
<!DOCTYPE doc [
  <!ELEMENT doc EMPTY>
  <!ATTLIST doc id ID #REQUIRED>
]>
<doc/>
-- dtd_fixed_attr.xml --
<?xml version="1.0"?>
<!DOCTYPE doc [
  <!ELEMENT doc EMPTY>
  <!ATTLIST doc version CDATA #FIXED "1.0">
]>
<doc version="1.0"/>
-- dtd_fixed_attr_wrong.xml --
<?xml version="1.0"?>
<!DOCTYPE doc [
  <!ELEMENT doc EMPTY>
  <!ATTLIST doc version CDATA #FIXED "1.0">
]>
<doc version="2.0"/>
-- dtd_choice.xml --
<?xml version="1.0"?>
<!DOCTYPE container [
  <!ELEMENT container (alpha | beta)>
  <!ELEMENT alpha (#PCDATA)>
  <!ELEMENT beta (#PCDATA)>
]>
<container><beta>hello</beta></container>
-- dtd_choice_both.xml --
<?xml version="1.0"?>
<!DOCTYPE container [
  <!ELEMENT container (alpha | beta)>
  <!ELEMENT alpha (#PCDATA)>
  <!ELEMENT beta (#PCDATA)>
]>
<container><alpha>a</alpha><beta>b</beta></container>
-- dtd_mixed.xml --
<?xml version="1.0"?>
<!DOCTYPE para [
  <!ELEMENT para (#PCDATA | bold)*>
  <!ELEMENT bold (#PCDATA)>
]>
<para>Hello <bold>world</bold> today</para>
-- schema.xsd --
<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <xs:element name="config">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="host" type="xs:string"/>
        <xs:element name="port" type="xs:integer"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
</xs:schema>
-- xsd_valid.xml --
<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="schema.xsd">
  <host>db.example.com</host>
  <port>5432</port>
</config>
-- xsd_invalid.xml --
<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="schema.xsd">
  <host>db.example.com</host>
  <port>not_a_number</port>
</config>
-- plain.xml --
<?xml version="1.0"?>
<root><key>value</key></root>
-- mapped.xml --
<?xml version="1.0"?>
<config>
  <host>db.example.com</host>
  <port>5432</port>
</config>
-- mapped_bad.xml --
<?xml version="1.0"?>
<config>
  <host>db.example.com</host>
  <port>not_a_number</port>
</config>
-- dtd_and_xsd.xml --
<?xml version="1.0"?>
<!DOCTYPE config [
  <!ELEMENT config (host, port)>
  <!ELEMENT host (#PCDATA)>
  <!ELEMENT port (#PCDATA)>
  <!ATTLIST config
    xmlns:xsi CDATA #IMPLIED
    xsi:noNamespaceSchemaLocation CDATA #IMPLIED>
]>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="schema.xsd">
  <host>db.example.com</host>
  <port>5432</port>
</config>
-- dtd_ok_xsd_bad.xml --
<?xml version="1.0"?>
<!DOCTYPE config [
  <!ELEMENT config (host, port)>
  <!ELEMENT host (#PCDATA)>
  <!ELEMENT port (#PCDATA)>
]>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="schema.xsd">
  <host>db.example.com</host>
  <port>not_a_number</port>
</config>
-- dtd_bad_xsd_ok.xml --
<?xml version="1.0"?>
<!DOCTYPE config [
  <!ELEMENT config (host, port, database)>
  <!ELEMENT host (#PCDATA)>
  <!ELEMENT port (#PCDATA)>
  <!ELEMENT database (#PCDATA)>
]>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="schema.xsd">
  <host>db.example.com</host>
  <port>5432</port>
</config>
