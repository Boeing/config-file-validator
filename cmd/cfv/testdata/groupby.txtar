# Group by filetype
exec cfv check -groupby=filetype files
stdout 'json'
stdout 'yaml'

# Group by directory
exec cfv check -groupby=directory files
stdout 'Summary'

# Group by pass-fail
exec cfv check -groupby=pass-fail files
stdout 'Passed'

# Group by error-type (all valid files → Passed group)
exec cfv check -groupby=error-type files
stdout 'Passed'

# Group by error-type with failures
! exec cfv check -groupby=error-type mixed
stdout 'syntax'
stdout 'Passed'

# Double grouping
exec cfv check -groupby=filetype,directory files
stdout 'json'

# Triple grouping
exec cfv check -groupby=pass-fail,filetype,directory files
stdout 'Passed'

# Four-level grouping
exec cfv check -groupby=filetype,directory,pass-fail,error-type files
stdout 'Passed'

# Groupby with JSON reporter
exec cfv check -groupby=filetype --reporter=json:- files
stdout 'totalPassed'

# Four-level grouping with JSON reporter
exec cfv check -groupby=filetype,directory,pass-fail,error-type --reporter=json:- files
stdout 'totalPassed'
stdout '"Passed"'

# Invalid groupby
! exec cfv check -groupby=badvalue files

# Duplicate groupby
! exec cfv check -groupby=directory,directory files

# Groupby not supported with junit
! exec cfv check -groupby=filetype --reporter=junit files

# Groupby not supported with sarif
! exec cfv check -groupby=filetype --reporter=sarif files

-- files/good.json --
{"key": "value"}
-- files/good.yaml --
key: value
-- mixed/good.json --
{"key": "value"}
-- mixed/bad.json --
{"key": value}
