# --schema-map with exact filename match
exec cfv check --schema-map=config.json:schema.json config.json
stdout '✓'

# --schema-map with invalid data fails
! exec cfv check --schema-map=bad.json:schema.json bad.json
stdout '×'
stdout 'error:'

# --schema-map with glob pattern
exec cfv check --schema-map=**/*.json:schema.json subdir/config.json
stdout '✓'

# --schema-map does not affect unmatched files
exec cfv check --schema-map=config.json:schema.json other.json
stdout '✓'

# --schema-map warns and still passes when matched file type has no schema support
exec cfv check --schema-map=.env:schema.json .env
stdout '✓'
stdout 'warning: --schema-map matched this file'

# --schema-map fails unsupported schema validators when schema is required
! exec cfv check --require-schema --schema-map=.env:schema.json .env
stdout '×'
stdout 'error: schema: --schema-map matched this file'
! stdout 'warning: --schema-map matched this file'

# Document $schema takes priority over --schema-map
exec cfv check --schema-map=with_schema.json:strict_schema.json with_schema.json
stdout '✓'

# Invalid --schema-map format
! exec cfv check --schema-map=badformat .
stderr 'invalid schema-map format'

-- schema.json --
{
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" }
  },
  "additionalProperties": false
}
-- strict_schema.json --
{
  "type": "object",
  "required": ["host"],
  "properties": {
    "host": { "type": "string" }
  },
  "additionalProperties": false
}
-- config.json --
{"name": "test", "version": "1.0"}
-- bad.json --
{"name": 123}
-- subdir/config.json --
{"name": "nested", "version": "2.0"}
-- other.json --
{"anything": "goes"}
-- .env --
KEY=VALUE
-- with_schema.json --
{
  "$schema": "schema.json",
  "name": "test",
  "version": "1.0"
}
