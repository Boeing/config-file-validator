# --ignore-file skips files matched by explicit ignore files without a git repo
exec cfv check --ignore-file=.dockerignore project
stdout '✓.*keep.json'
! stdout 'ignored.json'
! stdout 'build'

# Multiple ignore files are additive
exec cfv check --ignore-file=.dockerignore --ignore-file=.prettierignore multi
stdout '✓.*keep.json'
! stdout 'drop.json'
! stdout 'skip.yaml'

# Missing ignore files are skipped
exec cfv check --ignore-file=missing.ignore project
stdout 'keep.json'
stdout 'ignored.json'

# .cfv.toml ignore-files key works
exec cfv check --config=cfv/.cfv.toml cfv
stdout '✓.*app.json'
! stdout 'out.json'

# CFV_IGNORE_FILES env var works
env CFV_IGNORE_FILES=.dockerignore,.prettierignore
exec cfv check multi
stdout '✓.*keep.json'
! stdout 'drop.json'
! stdout 'skip.yaml'

-- project/.dockerignore --
ignored.json
build/
-- project/keep.json --
{"key": "value"}
-- project/ignored.json --
{"ignored": true}
-- project/build/output.json --
{"build": true}

-- multi/.dockerignore --
drop.json
-- multi/.prettierignore --
skip.yaml
-- multi/keep.json --
{"key": "value"}
-- multi/drop.json --
{"drop": true}
-- multi/skip.yaml --
skip: true

-- cfv/.cfv.toml --
ignore-files = [".dockerignore"]
-- cfv/.dockerignore --
gen/
-- cfv/app.json --
{"app": true}
-- cfv/gen/out.json --
{"gen": true}
