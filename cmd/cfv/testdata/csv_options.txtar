# ============================================================
# Functional tests for CSV validator options
# ============================================================

# Semicolon delimiter catches column mismatch
! exec cfv check --config=cfv/semicolon.toml bad_semicolon.csv
stdout '×'
stdout 'wrong number of fields'

# Semicolon delimiter passes valid file
exec cfv check --config=cfv/semicolon.toml good_semicolon.csv
stdout '✓'

# Comment character skips comment lines
exec cfv check --config=cfv/comment.toml commented.csv
stdout '✓'

# Tab delimiter
exec cfv check --config=cfv/tab.toml tab.csv
stdout '✓'

# Default delimiter still works
exec cfv check --no-config comma.csv
stdout '✓'

# Invalid validator option caught by schema
! exec cfv check --config=cfv/bad_option.toml comma.csv
stderr 'schema validation failed'

-- cfv/semicolon.toml --
[validators.csv]
delimiter = ";"

-- cfv/comment.toml --
[validators.csv]
comment = "#"

-- cfv/tab.toml --
[validators.csv]
delimiter = "\t"

-- cfv/bad_option.toml --
[validators.csv]
unknown_option = true

-- good_semicolon.csv --
name;age;city
Alice;30;NYC
Bob;25;LA

-- bad_semicolon.csv --
name;age;city
Alice;30;NYC
Bob;25

-- commented.csv --
# this is a comment
name,age
Alice,30

-- tab.csv --
name	age	city
Alice	30	NYC
Bob	25	LA

-- comma.csv --
name,age,city
Alice,30,NYC
Bob,25,LA
